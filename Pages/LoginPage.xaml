<Page x:Class="uch.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">
     
        <Grid Background="#F5F5F5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                <TextBlock Text="Читай, Пиши и не спиши" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" Foreground="#2C3E50"/>
            <TextBlock Text="логин"/>
            <TextBox x:Name="UsernameBox" Margin="0,5" Padding="10" Tag="Логин"/>
            <TextBlock Text="пароль"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5" Padding="10" Tag="Пароль"/>
                <Button Content="Войти" Click="Login_Click" Margin="0,20" Padding="10" Background="#3498DB" Foreground="White" FontSize="14"/>
                <Button Content="Регистрация" Click="Register_Click" Background="#2ECC71" Foreground="White" Padding="10" FontSize="14"/>
            </StackPanel>
        </Grid>
    </Page>