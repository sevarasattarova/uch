<Page x:Class="uch.Pages.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditBookPage">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
            <TextBlock Text="Название"/>
            <TextBox x:Name="TitleBox" Margin="0,5" Padding="5" Tag="Название"/>
            <TextBlock Text="Описание"/>

            <TextBox x:Name="DescriptionBox" Margin="0,5" Padding="5" Tag="Описание" TextWrapping="Wrap" Height="100"/>
            <TextBlock Text="Текст книги"/>

            <TextBox x:Name="TextContentBox" Margin="0,5" Padding="5" Tag="Текст книги" TextWrapping="Wrap" Height="200"/>
            <TextBlock Text="URL обложки"/>

            <TextBox x:Name="CoverUrlBox" Margin="0,5" Padding="5" Tag="URL обложки"/>
                <TextBlock Text="Жанры" Margin="0,10,0,5"/>
                <ListBox x:Name="GenresList" SelectionMode="Multiple" DisplayMemberPath="Name" Height="150"/>
                <Button Content="Сохранить" Click="SaveBook_Click" Margin="0,20" Background="#2ECC71" Foreground="White" Padding="10"/>
            </StackPanel>
        </ScrollViewer>
    </Page>