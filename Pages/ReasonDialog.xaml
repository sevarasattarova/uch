<Window x:Class="uch.Pages.ReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Причина разморозки" Height="300" Width="450"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Text="Укажите причину для разморозки:" 
                   FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
        <TextBox x:Name="AnswerBox" TextWrapping="Wrap" Height="120" 
                 AcceptsReturn="True" Margin="0,0,0,15"/>
        <Button Content="Отправить" Click="Ok_Click" Background="#2ECC71" 
                Foreground="White" Padding="10,5"/>
        <Button Content="Отмена" Click="Cancel_Click" Margin="0,5,0,0" 
                Background="#95A5A6" Foreground="White" Padding="10,5"/>
    </StackPanel>
</Window>