<Page x:Class="uch.Pages.AppealPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AppealPage" Background="White">




        <Grid Background="#FFF5F5F5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                <Border Background="White" CornerRadius="15" Padding="25" BorderBrush="#E74C3C" BorderThickness="2">
                    <StackPanel>
                        <!-- Иконка предупреждения -->

                        <TextBlock Text="ВАШ АККАУНТ ЗАМОРОЖЕН" FontSize="22" FontWeight="Bold" 
                               Foreground="#E74C3C" HorizontalAlignment="Center" Margin="0,10,0,10"/>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="Причина заморозки:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border Background="#FFF0F0" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                            <TextBlock x:Name="FreezeReasonText" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Что делать?" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="Вы можете подать заявку на разморозку аккаунта. Администратор рассмотрит вашу заявку и примет решение." 
                               TextWrapping="Wrap" Margin="0,0,0,15" Foreground="#555"/>

                        <Button Content="📝 Подать заявку на разморозку" 
                            Click="SubmitAppeal_Click" 
                            Background="#F39C12" Foreground="White" 
                            Padding="15,10" FontSize="14" Margin="0,5"/>

                        <Button Content="Выйти" 
                            Click="BackToLogin_Click" 
                            Background="#95A5A6" Foreground="White" 
                            Padding="15,10" FontSize="14" Margin="0,10"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Page>