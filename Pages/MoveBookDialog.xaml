<Window x:Class="uch.Pages.MoveBookDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:uch.Pages"
        mc:Ignorable="d"
        Title="MoveBookDialog" Height="450" Width="800">
   
        <StackPanel Margin="20">
            <TextBlock Text="Переместить в:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ComboBox x:Name="TargetListCombo" Margin="0,0,0,20">
                <ComboBoxItem Content="📖 Читаю" Tag="Reading"/>
                <ComboBoxItem Content="📚 Прочитано" Tag="Read"/>
                <ComboBoxItem Content="📅 В планах" Tag="Planned"/>
                <ComboBoxItem Content="❌ Заброшено" Tag="Dropped"/>
            </ComboBox>
            <Button Content="Переместить" Click="Move_Click" Background="#3498DB" Foreground="White" Padding="8"/>
            <Button Content="Отмена" Click="Cancel_Click" Margin="0,5,0,0" Background="#95A5A6" Foreground="White" Padding="8"/>
        </StackPanel>
    </Window>