<Page x:Class="uch.Pages.ReadBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReadBookPage" Background="White">
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="#2C3E50" Padding="10">
                <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
            </Border>
            <ScrollViewer Grid.Row="1">
                <TextBlock x:Name="ContentText" Text="{Binding TextContent}" FontSize="16" Margin="30" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Grid>
    </Page>