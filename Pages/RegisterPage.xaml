<Page x:Class="uch.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    
        <Grid Background="#F5F5F5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <TextBlock Text="Регистрация" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>
            <TextBlock Text="Никнейм"/>
            <TextBox x:Name="UsernameBox" Margin="0,5" Padding="10" Tag="Логин"/>
            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox" Margin="0,5" Padding="10" Tag="Email"/>
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5" Padding="10" Tag="Пароль"/>
                <TextBlock Text="Повторите пароль"/>
                   <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,5" Padding="10" Tag="Повторите пароль"/>
                <Button Content="Зарегистрироваться" Click="Register_Click" Margin="0,20" Padding="10" Background="#2ECC71" Foreground="White" FontSize="14"/>
                <Button Content="Назад" Click="Back_Click" Background="#95A5A6" Foreground="White" Padding="10" FontSize="14"/>
            </StackPanel>
        </Grid>
    </Page>
