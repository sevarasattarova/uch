<Page x:Class="uch.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:uch.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage" Background="White">


        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Информация о пользователе" FontWeight="Bold" FontSize="20" Margin="0,0,0,10"/>
                <TextBlock x:Name="UserInfo" Margin="0,10" FontSize="14"/>
                <Button x:Name="RequestAuthorBtn" Content="Подать заявку на роль автора" Click="RequestAuthor_Click" Background="#3498DB" Foreground="White" Margin="0,20" Padding="10"/>
                <TextBlock Text="Мои отзывы" FontWeight="Bold" FontSize="18" Margin="0,10"/>
                <ListBox x:Name="MyReviewsList">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding BookTitle}" FontWeight="Bold"/>
                                    <TextBlock Text="Оценка: {Binding Rating}⭐"/>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Page>